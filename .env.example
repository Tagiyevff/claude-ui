# Environment Variables (Optional)

# Ollama Configuration
# VITE_OLLAMA_BASE_URL=http://localhost:11434

# OpenAI Configuration
# VITE_OPENAI_API_KEY=sk-...
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Configuration
# VITE_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini Configuration
# VITE_GOOGLE_API_KEY=...

# Groq Configuration
# VITE_GROQ_API_KEY=...

# OpenRouter Configuration
# VITE_OPENROUTER_API_KEY=...

# Custom API Configuration
# VITE_CUSTOM_API_BASE_URL=https://your-api.com/v1
# VITE_CUSTOM_API_KEY=...

# Proxy Configuration (Optional)
# VITE_PROXY_URL=http://proxy.example.com:8080

# Note: TagUI stores API keys in browser localStorage for security.
# Environment variables are optional and can be used for default configuration.
# All settings can be configured through the Settings UI in the application.
